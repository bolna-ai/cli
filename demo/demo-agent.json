{
  "agent_config": {
    "agent_name": "Aria - Demo Support Agent",
    "agent_welcome_message": "Hi, this is Aria from Acme Corp. How can I help you today?",
    "agent_type": "other",
    "tasks": [
      {
        "task_type": "conversation",
        "tools_config": {
          "llm_agent": {
            "agent_type": "simple_llm_agent",
            "agent_flow_type": "streaming",
            "llm_config": { "provider": "openai", "family": "openai", "model": "gpt-4.1-mini", "max_tokens": 200, "temperature": 0.2 }
          },
          "synthesizer": {
            "provider": "elevenlabs",
            "provider_config": { "voice": "Nila", "voice_id": "V9LCAAi4tTlqe9JadbCo", "model": "eleven_turbo_v2_5" },
            "stream": true,
            "audio_format": "wav"
          },
          "transcriber": {
            "provider": "deepgram", "model": "nova-3", "language": "en",
            "stream": true, "encoding": "linear16", "sampling_rate": 16000, "endpointing": 400
          },
          "input": { "provider": "twilio", "format": "wav" },
          "output": { "provider": "twilio", "format": "wav" }
        },
        "toolchain": { "execution": "parallel", "pipelines": [["transcriber", "llm", "synthesizer"]] }
      }
    ]
  },
  "agent_prompts": {
    "task_1": { "system_prompt": "You are Aria, a friendly customer support voice agent for Acme Corp. Keep every response under two sentences. Greet callers warmly, answer product questions, and offer to connect them to a human for anything you can't resolve." }
  }
}
